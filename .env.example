# LangSmith Configuration (for observability and evaluation)
# Get your API key from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=ls_your_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=medical-chatbot

# Alternative: Use LANGCHAIN_API_KEY (same as LANGSMITH_API_KEY)
# LANGCHAIN_API_KEY=ls_your_api_key_here

# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: LangSmith Endpoint (usually not needed)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Google Cloud Storage — FAISS vectorstore persistence
# Set to your GCS bucket name to enable cloud storage for the FAISS index.
# Leave unset (or empty) to use local filesystem only (good for local dev).
# On Cloud Run this is set automatically via --set-env-vars in cd.yml.
# How to create: GCP Console → Cloud Storage → Create Bucket
GCS_BUCKET_NAME=your-gcs-bucket-name

# Authentication (Streamlit-Authenticator)
AUTH_COOKIE_KEY=random_secret_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password_here
STANDARD_USERNAME=user
STANDARD_PASSWORD=user_password_here
